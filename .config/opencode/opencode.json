{
  "$schema": "https://opencode.ai/config.json",
  "share": "manual",
  "autoupdate": false,
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  },
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": [
        "context-mode"
      ]
    }
  },
  "plugin": [
    "context-mode",
    "./plugins/caveman/plugin.js"
  ]
}
